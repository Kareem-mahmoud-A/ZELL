rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper checks
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isAdmin() {
      return hasRole('admin') || hasRole('superadmin');
    }

    // Product Images: Publicly readable, writeable only by Admin
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && request.resource.size < 5 * 1024 * 1024 && request.resource.contentType.matches('image/.*');
    }

    // User Private Files (invoices, shipping labels): Readable by owner or Admin
    match /users/{userId}/documents/{allPaths=**} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
